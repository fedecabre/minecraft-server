# 🔐 IMPORTANT: This file is safe to share - it's a template only!
# Create your .env file by copying this and filling in YOUR values
# .env is automatically ignored by Git (.gitignore)

# ===== DuckDNS Configuration =====
# Get your free domain at https://www.duckdns.org
# Example: myserver.duckdns.org

DOMAIN_ROOT=duckdns.org

# Replace 'mysubdomain' with your DuckDNS subdomain
DOMAIN_TRAEFIK=mysubdomain.duckdns.org
DOMAIN_MINECRAFT=mysubdomain.duckdns.org
DOMAIN_MCADMIN=mysubdomain.duckdns.org

# ===== Let's Encrypt Email =====
# Used to receive certificate renewal alerts
EMAIL=your-email@example.com

# ===== Security Secrets (CHANGE THESE!) =====
# Generate random values with:
# - Passwords: openssl rand -base64 12
# - Secret key: openssl rand -hex 16

VELOCITY_FORWARDING_SECRET=CHANGE_ME_random_secret_here
DOMAIN=duckdns.org

# ===== Admin Credentials =====
# Minecraft server admin
MCADMIN_USER=admin
MCADMIN_PASS=CHANGE_ME_secure_password
MCADMIN_SERVER_NAME=My Minecraft Server

# Crafty Controller admin (if used)
CRAFTY_USER=admin
CRAFTY_PASS=CHANGE_ME_secure_password
