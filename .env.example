# Domain and hostname configuration
DOMAIN=example.com
MINECRAFT_HOST=minecraft
TRAEFIK_HOST=traefik

# Email for Let's Encrypt notifications (required)
EMAIL=your-email@example.com

# Security settings - USE STRONG RANDOM VALUE - DO NOT SHARE
# Generate with: openssl rand -hex 16
VELOCITY_FORWARDING_SECRET=replace_with_random_string

# Optional: For Traefik dashboard basic auth (uncomment related lines in docker-compose.yml)
# Generate with: htpasswd -nb username password
# TRAEFIK_DASHBOARD_AUTH=admin:$hashed_password_here

# Minecraft server settings
MC_MEMORY=4G
MC_VERSION=LATEST
MC_SERVER_NAME="My Minecraft Server"
